generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("kasir") // admin | kasir
  outletId  String?
  outlet    Outlet?  @relation(fields: [outletId], references: [id])
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
}

model Outlet {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users        User[]
  services     Service[]
  transactions Transaction[]
}

model Category {
  id        String     @id @default(cuid())
  name      String
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())

  services Service[]
}

model Service {
  id         String   @id @default(cuid())
  name       String
  price      Float
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  outletId   String?
  outlet     Outlet?   @relation(fields: [outletId], references: [id])
  active     Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  transactionItems TransactionItem[]
}

model Transaction {
  id            String   @id @default(cuid())
  invoiceNo     String   @unique
  outletId      String
  outlet        Outlet   @relation(fields: [outletId], references: [id])
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  customerId    String?
  customer      Customer? @relation(fields: [customerId], references: [id])
  totalAmount   Float
  status        String   @default("completed") // completed | cancelled
  note          String?
  createdAt     DateTime @default(now())
  cancelUser    String?
  approvedUser  String?
  cancelDate    DateTime?
  cancelReason  String?

  items    TransactionItem[]
  payments Payment[]
}

model TransactionItem {
  id              String      @id @default(cuid())
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  serviceId       String
  service         Service     @relation(fields: [serviceId], references: [id])
  serviceName     String
  qty             Int         @default(1)
  price           Float
  originalPrice   Float?
  discountPercent Float?      @default(0)
  subtotal        Float
}

model Payment {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  method        String      // cash | transfer | qris
  amount        Float
  createdAt     DateTime    @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model Discount {
  id              String   @id @default(cuid())
  type            String   // 'category' | 'service'
  targetId        String   // categoryId or serviceId
  targetName      String?  // cached name for display
  discountPercent Float
  dateFrom        DateTime
  dateTo          DateTime
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions   Transaction[]
  rewardClaims   RewardClaim[]
  pendingRewards PendingReward[]
}

model LoyaltyConfig {
  id               String  @id @default(cuid())
  minTransactions  Int     @default(10)    // jumlah transaksi minimum
  withinDays       Int     @default(30)    // dalam rentang hari
  claimDaysLimit   Int     @default(60)    // batas hari untuk klaim reward setelah unlock
  rewardServiceId  String?                 // service yang diberikan gratis (nullable = bebas pilih)
  isActive         Boolean @default(true)  // aktif/nonaktif fitur
}

model PendingReward {
  id          String    @id @default(cuid())
  customerId  String
  customer    Customer  @relation(fields: [customerId], references: [id])
  unlockedAt  DateTime  @default(now())  // kapan reward ter-unlock
  expiresAt   DateTime                    // batas waktu klaim (unlockedAt + claimDaysLimit)
  status      String    @default("pending") // pending | claimed | expired
  claimedAt   DateTime?
  claimTransactionId String?              // transaksi dimana reward diklaim

  @@index([customerId, status])
}

model RewardClaim {
  id            String      @id @default(cuid())
  customerId    String
  customer      Customer    @relation(fields: [customerId], references: [id])
  transactionId String?
  claimedAt     DateTime    @default(now())
}
